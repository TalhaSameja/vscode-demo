{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node10",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "types": ["node"],
    "ignoreDeprecations": "5.0"
  },
  "include": [
    "pages/**/*.ts",
    "support/**/*.ts",
    "step-definitions/**/*.ts"
  ]
}
